// Rise Foods ERP + CRM — Prisma Schema
// FMCG food manufacturing & distribution operating system
// Database: SQLite (Dev) — same model maps to Postgres in prod via Appwrite parity

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH & RBAC
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  avatar       String?
  role         String   @default("staff") // owner | admin | purchase_manager | warehouse_manager | sales_manager | salesman | accountant | factory_staff | delivery_staff | retailer | distributor
  employeeId   String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs    AuditLog[]
  salesOrders  SalesOrder[]   @relation("SalesOrderCreatedBy")
  salesOrdersAsSalesman SalesOrder[] @relation("SalesOrderSalesman")
  purchaseOrders PurchaseOrder[] @relation("POCreatedBy")
  customers    Customer[]     @relation("SalesmanCustomer")
  visits       Visit[]
  tasks        Task[]
  insights     AIInsight[]    @relation("InsightGeneratedBy")
  notifications Notification[] @relation("NotifRecipient")
  productionBatches ProductionBatch[] @relation("Operator")
  payments     Payment[]      @relation("PaymentCollectedBy")
  expenses     Expense[]      @relation("ExpenseCreatedBy")
  stockMovements StockMovement[] @relation("MovementBy")
  cashEntries  CashEntry[]    @relation("CashEntryBy")
  journalEntries JournalEntry[] @relation("JournalEntryBy")
  targets      Target[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String   // JSON-serialized permission matrix
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // create | update | delete | login | logout | export
  entity     String   // customer | product | order | ...
  entityId   String?
  oldValue   String?  // JSON
  newValue   String?  // JSON
  ip         String?
  device     String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Retailers, Distributors, Leads
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id                String   @id @default(cuid())
  businessName      String
  ownerName         String?
  phone             String
  alternatePhone    String?
  email             String?
  gst               String?
  fssai             String?
  address           String
  district          String
  area              String
  pin               String?
  geoLat            Float?
  geoLng            Float?
  type              String   @default("retailer") // retailer | distributor | horeca | lead
  salesmanId        String?
  salesman          User?    @relation("SalesmanCustomer", fields: [salesmanId], references: [id], onDelete: SetNull)
  creditLimit       Float    @default(0)
  creditDays        Int      @default(0)
  outstanding       Float    @default(0)
  status            String   @default("lead") // lead | active | inactive | blocked
  riskScore         Float    @default(0) // 0–100
  retentionScore    Float    @default(0)
  orderFrequency    Float    @default(0) // orders/month
  avgOrderValue     Float    @default(0)
  lifetimeValue     Float    @default(0)
  profitGenerated   Float    @default(0)
  lastOrderAt       DateTime?
  lastPaymentAt     DateTime?
  notes             String?
  preferredProducts String?  // JSON array of product IDs
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  salesOrders       SalesOrder[]
  invoices          Invoice[]
  payments          Payment[]
  visits            Visit[]
  timeline          TimelineEntry[]
  tasks             Task[]

  @@index([district])
  @@index([area])
  @@index([salesmanId])
  @@index([status])
  @@index([type])
}

model TimelineEntry {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String   // note | call | visit | whatsapp | invoice | payment | order | email
  title      String
  body       String?
  metadata   String?  // JSON
  createdBy  String?
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS & CATEGORIES
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  sku             String   @unique
  barcode         String?
  name            String
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand           String   @default("Rise Foods")
  description     String?
  hsn             String?
  gstRate         Float    @default(5)
  mrp             Float
  wholesalePrice  Float
  distributorPrice Float
  retailPrice     Float
  costPrice       Float
  marginPercent   Float    @default(0)
  packagingSize   String?  // 100g, 500g, 1kg
  shelfLifeDays   Int      @default(540)
  moq             Int      @default(1)
  reorderLevel    Int      @default(10)
  abcClass        String   @default("C") // A | B | C
  xyzClass        String   @default("Z") // X | Y | Z (demand variability)
  image           String?
  status          String   @default("active") // active | discontinued | draft
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inventory       Inventory[]
  stockMovements  StockMovement[]
  poItems         PurchaseOrderItem[]
  soItems         SalesOrderItem[]
  productionLines ProductionBatchItem[]
  batches         Batch[]

  @@index([categoryId])
  @@index([status])
  @@index([abcClass])
}

// ─────────────────────────────────────────────────────────────────────────────
// WAREHOUSE & INVENTORY
// ─────────────────────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String
  district  String
  manager   String?
  phone     String?
  racks     Rack[]
  inventory Inventory[]
  batches   Batch[]
  purchaseOrders PurchaseOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rack {
  id          String   @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  code        String
  zone        String?
  capacity    Int?
  createdAt   DateTime @default(now())
}

model Batch {
  id            String   @id @default(cuid())
  batchNo       String   @unique
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId   String?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  quantity      Int
  reservedQty   Int      @default(0)
  costPrice     Float
  mfgDate       DateTime
  expiryDate    DateTime
  receivedAt    DateTime @default(now())
  status        String   @default("in_stock") // in_stock | partial | empty | expired | damaged
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([expiryDate])
  @@index([status])
}

model Inventory {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  currentStock  Int      @default(0)
  reservedStock Int      @default(0)
  incomingStock Int      @default(0)
  reorderLevel  Int      @default(10)
  reorderQty    Int      @default(50)
  lastStockAt   DateTime?
  valuation     Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([productId, warehouseId])
  @@index([warehouseId])
}

model StockMovement {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId  String
  batchId      String?
  type         String   // stock_in | stock_out | transfer | return | damaged | lost | expired | adjustment | reserved | released
  quantity     Int
  refType      String?  // purchase | sales | production | adjustment
  refId        String?
  note         String?
  createdBy    String?
  user         User?    @relation("MovementBy", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([productId])
  @@index([warehouseId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROCUREMENT — Suppliers, POs, GRN
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id             String   @id @default(cuid())
  name           String
  contactPerson  String?
  phone          String
  email          String?
  gst            String?
  address        String
  district       String
  rating         Float    @default(3.5) // 0–5
  leadTimeDays   Int      @default(7)
  paymentTerms   String?
  outstanding    Float    @default(0)
  totalPurchased Float    @default(0)
  onTimeRate     Float    @default(0)
  qualityRate    Float    @default(0)
  status         String   @default("active") // active | blocked | blacklist
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  batches        Batch[]
  quotations     Quotation[]
}

model Quotation {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId   String?
  productName String
  unit        String
  price       Float
  moq         Int      @default(1)
  validTill   DateTime
  status      String   @default("open") // open | accepted | rejected | expired
  createdAt   DateTime @default(now())
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  poNo          String   @unique
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  status        String   @default("draft") // draft | sent | partial | received | closed | cancelled
  subtotal      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  paid          Float    @default(0)
  expectedAt    DateTime?
  receivedAt    DateTime?
  notes         String?
  createdBy     String?
  created       User?    @relation("POCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  items         PurchaseOrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id           String   @id @default(cuid())
  poId         String
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  receivedQty  Int      @default(0)
  unitCost     Float
  taxPercent   Float    @default(5)
  total        Float
}

// ─────────────────────────────────────────────────────────────────────────────
// SALES — Orders, Invoices, Payments, Dispatch
// ─────────────────────────────────────────────────────────────────────────────

model SalesOrder {
  id            String   @id @default(cuid())
  orderNo       String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  salesmanId    String?
  salesman      User?    @relation("SalesOrderSalesman", fields: [salesmanId], references: [id], onDelete: SetNull)
  status        String   @default("pending") // pending | packed | dispatched | delivered | cancelled | returned
  paymentStatus String   @default("unpaid") // unpaid | partial | paid
  subtotal      Float    @default(0)
  tax           Float    @default(0)
  discount      Float    @default(0)
  total         Float    @default(0)
  paid          Float    @default(0)
  profit        Float    @default(0)
  itemsCount    Int      @default(0)
  channel       String   @default("direct") // direct | portal | whatsapp | phone
  notes         String?
  createdBy     String?
  created       User?    @relation("SalesOrderCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  packedAt      DateTime?
  dispatchedAt  DateTime?
  deliveredAt   DateTime?
  cancelledAt   DateTime?
  deliveryAddress String?
  deliveryVehicleId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         SalesOrderItem[]
  invoices      Invoice[]
  payments      Payment[]
  dispatch      Dispatch?

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model SalesOrderItem {
  id           String   @id @default(cuid())
  soId         String
  so           SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  unitPrice    Float
  unitCost     Float
  taxPercent   Float    @default(5)
  discount     Float    @default(0)
  total        Float
  profit       Float
}

model Invoice {
  id           String   @id @default(cuid())
  invoiceNo    String   @unique
  orderId      String
  order        SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  type         String   @default("sales") // sales | credit_note | debit_note | proforma
  subtotal     Float
  tax          Float
  total        Float
  paid         Float    @default(0)
  balance      Float    @default(0)
  status       String   @default("unpaid") // unpaid | partial | paid | overdue | cancelled
  dueDate      DateTime?
  pdfUrl       String?
  createdAt    DateTime @default(now())

  @@index([customerId])
  @@index([status])
}

model Payment {
  id           String   @id @default(cuid())
  paymentNo    String   @unique
  orderId      String?
  order        SalesOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  invoiceId    String?
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  amount       Float
  method       String   @default("cash") // cash | upi | bank | cheque | credit
  reference    String?
  status       String   @default("completed") // pending | completed | failed | reversed
  collectedBy  String?
  collector    User?    @relation("PaymentCollectedBy", fields: [collectedBy], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
}

model Dispatch {
  id           String   @id @default(cuid())
  dispatchNo   String   @unique
  orderId      String   @unique
  order        SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vehicleId    String?
  driverName   String?
  driverPhone  String?
  status       String   @default("pending") // pending | loaded | in_transit | delivered | failed
  loadedAt     DateTime?
  deliveredAt  DateTime?
  notes        String?
  createdAt    DateTime @default(now())
}

model Vehicle {
  id           String   @id @default(cuid())
  number       String   @unique
  type         String   // bike | tempo | truck | van
  capacity     Float?
  driverName   String?
  driverPhone  String?
  status       String   @default("available") // available | on_route | maintenance
  createdAt    DateTime @default(now())
}

model Route {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  salesmanId String?
  districts String?  // JSON array
  stops     Int      @default(0)
  createdAt DateTime @default(now())
}

model Visit {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesmanId String?
  salesman   User?    @relation(fields: [salesmanId], references: [id], onDelete: SetNull)
  type       String   @default("sales") // sales | collection | service | new_lead
  status     String   @default("planned") // planned | completed | missed
  notes      String?
  orderValue Float?
  collected  Float?
  scheduledAt DateTime
  completedAt DateTime?
  geoLat     Float?
  geoLng     Float?
  createdAt  DateTime @default(now())

  @@index([salesmanId, scheduledAt])
}

model Task {
  id         String   @id @default(cuid())
  title      String
  description String?
  assigneeId String?
  assignee   User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  type       String   @default("followup") // followup | collection | delivery | order | other
  priority   String   @default("medium") // low | medium | high | urgent
  status     String   @default("open") // open | in_progress | done | cancelled
  dueDate    DateTime?
  completedAt DateTime?
  createdAt  DateTime @default(now())
}

model Target {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period     String   // monthly | quarterly | yearly
  periodKey  String   // e.g. 2026-06
  metric     String   // revenue | orders | new_customers | collection
  target     Float
  achieved   Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, period, periodKey, metric])
}

// ─────────────────────────────────────────────────────────────────────────────
// FINANCE
// ─────────────────────────────────────────────────────────────────────────────

model Expense {
  id           String   @id @default(cuid())
  category     String   // rent | salary | utility | transport | marketing | packaging | misc | cogs
  subcategory  String?
  amount       Float
  date         DateTime
  vendor       String?
  paymentMode  String   @default("cash")
  status       String   @default("paid") // paid | pending
  note         String?
  createdBy    String?
  user         User?    @relation("ExpenseCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([category, date])
  @@index([date])
}

model BankAccount {
  id           String   @id @default(cuid())
  name         String
  bank         String
  accountNo    String
  ifsc         String?
  branch       String?
  balance      Float    @default(0)
  type         String   @default("current") // current | savings | cash | upi
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CashEntry {
  id           String   @id @default(cuid())
  type         String   // receipt | payment
  amount       Float
  category     String
  description  String
  refType      String?
  refId        String?
  accountId    String?
  createdBy    String?
  user         User?    @relation("CashEntryBy", fields: [createdBy], references: [id], onDelete: SetNull)
  date         DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([type, date])
  @@index([date])
}

model JournalEntry {
  id           String   @id @default(cuid())
  entryNo      String   @unique
  date         DateTime
  description  String
  debitAccount String
  creditAccount String
  amount       Float
  refType      String?
  refId        String?
  createdBy    String?
  user         User?    @relation("JournalEntryBy", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([date])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTION
// ─────────────────────────────────────────────────────────────────────────────

model ProductionBatch {
  id           String   @id @default(cuid())
  batchNo      String   @unique
  productId    String?
  startDate    DateTime
  endDate      DateTime?
  stage        String   @default("cleaning") // cleaning | grinding | packing | finished | qc
  inputQty     Float    @default(0)
  outputQty    Float    @default(0)
  yieldPercent Float    @default(0)
  lossPercent  Float    @default(0)
  machineId    String?
  machineName  String?
  operatorId   String?
  operator     User?    @relation("Operator", fields: [operatorId], references: [id], onDelete: SetNull)
  cost         Float    @default(0)
  downtime     Int      @default(0) // minutes
  notes        String?
  items        ProductionBatchItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([stage])
}

model ProductionBatchItem {
  id           String   @id @default(cuid())
  batchId      String
  batch        ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  type         String   // raw_material | finished_good
  quantity     Float
  unit         String
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS & AI INSIGHTS
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  type       String   // low_stock | pending_payment | new_order | dispatch | failed_delivery | customer_inactive | supplier_delay | inventory_expiry | daily_summary | system
  title      String
  body       String?
  severity   String   @default("info") // info | warning | critical | success
  refType    String?
  refId      String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model AIInsight {
  id           String   @id @default(cuid())
  type         String   // trend | anomaly | recommendation | forecast | risk
  category     String   // sales | inventory | finance | customer | procurement
  title        String
  body         String
  severity     String   @default("info") // info | warning | critical | success
  metric       String?
  metricValue  Float?
  deltaPercent Float?
  recommendation String?
  refType      String?
  refId        String?
  isActioned   Boolean  @default(false)
  generatedBy  String?
  generator    User?    @relation("InsightGeneratedBy", fields: [generatedBy], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([category, severity])
  @@index([createdAt])
}

model Setting {
  id         String   @id @default(cuid())
  key        String   @unique
  value      String
  category   String   @default("general") // general | finance | inventory | sales | notifications
  updatedAt  DateTime @updatedAt
}
